    {
      "id": "llamacpp",
      "label": "llama.cpp",
      "icon": "L",
      "pricing_tag": "free",
      "scan": {
        "binary": "llama-cli",
        "alt_binaries": ["llama-server"],
        "extra_paths": [],
        "running_patterns": ["llama-server", "llama-cli"]
      },
      "start": { "args": [], "needs_model": false }
    },
    {
      "id": "localai",
      "label": "LocalAI",
      "icon": "A",
      "pricing_tag": "free",
      "scan": {
        "binary": "local-ai",
        "extra_paths": [],
        "running_patterns": ["local-ai"]
      },
      "start": { "args": [], "needs_model": false }
    },
    {
      "id": "gpt4all",
      "label": "GPT4All",
      "icon": "G",
      "pricing_tag": "free",
      "scan": {
        "binary": "gpt4all",
        "extra_paths": [],
        "running_patterns": ["gpt4all"]
      },
      "start": { "args": [], "needs_model": false }
    },
    {
      "id": "lmstudio",
      "label": "LM Studio",
      "icon": "S",
      "pricing_tag": "free",
      "scan": {
        "binary": null,
        "port": 1234,
        "running_patterns": []
      },
      "start": null
    },
    {
      "id": "vllm",
      "label": "vLLM",
      "icon": "V",
      "pricing_tag": "free",
      "scan": {
        "binary": null,
        "port": 8000,
        "running_patterns": ["vllm"]
      },
      "start": null
    },
    {
      "id": "bash",
      "label": "Bash Shell",
      "icon": "$",
      "pricing_tag": "free",
      "hidden_in_wizard": true,
      "scan": null,
      "start": { "binary": "bash", "args": [], "needs_model": false }
    }
  ]
}
