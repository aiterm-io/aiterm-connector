#!/bin/bash
# AITerm Connector CLI
PY="/usr/bin/python3"

# Auto-detect install location
if [ -d "/opt/aiterm" ] && [ -f "/opt/aiterm/connector.py" ]; then
    DIR="/opt/aiterm"
    SVC="systemctl"
elif [ -d "$HOME/.local/share/aiterm" ] && [ -f "$HOME/.local/share/aiterm/connector.py" ]; then
    DIR="$HOME/.local/share/aiterm"
    SVC="systemctl --user"
else
    echo "  AITerm not found. Install:"
    echo "  curl -sL https://aiterm.io/install | bash"
    exit 1
fi

# Check if systemctl works (user mode may not have D-Bus session)
SVC_WORKS=1
if [ "$SVC" = "systemctl --user" ]; then
    $SVC is-system-running &>/dev/null || SVC_WORKS=0
fi

# Print PIDs of pty-manager / connector instances that are *not* the
# process systemd is tracking. These "strangers" come from someone
# running `aiterm start` (or `python3 pty-manager.py`) by hand while
# the service was already up — systemctl won't reach them on stop or
# restart, and they end up double-bound to pty.sock and competing with
# the legitimate process. The hub then sees malformed/duplicate frames
# and starts dropping connections with 1011. Caller decides what to do
# with the list (status: warn; restart: kill).
find_strangers() {
    [ "$SVC_WORKS" -eq 1 ] || return 0
    local kind="$1" script main pid
    case "$kind" in
        pty)        script="$DIR/pty-manager.py";  main=$($SVC show -p MainPID --value aiterm-pty 2>/dev/null || echo 0) ;;
        connector)  script="$DIR/connector.py";    main=$($SVC show -p MainPID --value aiterm-connector 2>/dev/null || echo 0) ;;
        *) return 0 ;;
    esac
    for pid in $(pgrep -f "python3.*$script" 2>/dev/null); do
        [ "$pid" != "$main" ] && [ -n "$pid" ] && echo "$pid"
    done
}

case "${1:-}" in
  update)   exec $PY "$DIR/connector.py" --update ;;
  scan)     exec $PY "$DIR/connector.py" --scan ;;
  doctor)   shift; exec $PY "$DIR/doctor.py" "$@" ;;
  pair|repair)
    # Re-pair this machine with a fresh token (keeps the name, keeps code,
    # restores old pairing if the flow fails). Use when the machine was
    # removed from the hub or you want to move it to a different account.
    exec bash -c "$(curl -sSL https://aiterm.io/install)" bash --pair
    ;;
  status)
    echo ""
    if [ "$SVC_WORKS" -eq 1 ]; then
      for svc in aiterm-connector aiterm-pty; do
        STATE=$($SVC is-active $svc 2>/dev/null || echo "not running")
        if [ "$STATE" = "active" ]; then
          echo -e "  \033[0;32m●\033[0m $svc"
        else
          echo -e "  \033[0;31m●\033[0m $svc ($STATE)"
        fi
      done
      # Surface stranger processes — the failure mode is silent otherwise:
      # systemctl reports green while a parallel pty-manager is corrupting
      # the hub session.
      pty_strangers=$(find_strangers pty)
      conn_strangers=$(find_strangers connector)
      if [ -n "$pty_strangers" ] || [ -n "$conn_strangers" ]; then
        echo ""
        echo -e "  \033[0;33m!\033[0m Stranger processes detected (running outside systemd):"
        [ -n "$pty_strangers" ]  && echo "      pty-manager: $pty_strangers"
        [ -n "$conn_strangers" ] && echo "      connector:   $conn_strangers"
        echo "      Run 'aiterm restart' to clean up."
      fi
    else
      if pgrep -f "python3.*$DIR/pty-manager.py" &>/dev/null; then
        echo -e "  \033[0;32m●\033[0m pty-manager"
      else
        echo -e "  \033[0;31m●\033[0m pty-manager (not running)"
      fi
      if pgrep -f "python3.*$DIR/connector.py" &>/dev/null; then
        echo -e "  \033[0;32m●\033[0m connector"
      else
        echo -e "  \033[0;31m●\033[0m connector (not running)"
      fi
    fi
    echo ""
    if [ -f "$DIR/connector.json" ]; then
      $PY -c "
import json
c=json.load(open('$DIR/connector.json'))
print(f\"  Host:  {c.get('name','?')}\")
print(f\"  Hub:   {c.get('hub_url','?')}\")
print(f\"  Dir:   $DIR\")
"
      echo ""
    fi
    ;;
  start)
    # Refuse to spawn duplicates — that's how parallel pty-managers
    # double-bind to pty.sock and corrupt sessions. Always check both
    # processes first and prefer systemd's idempotent start when it
    # owns the unit. Pure manual mode also checks before nohup.
    pty_alive=0
    conn_alive=0
    pgrep -f "python3.*$DIR/pty-manager.py" &>/dev/null && pty_alive=1
    pgrep -f "python3.*$DIR/connector.py"   &>/dev/null && conn_alive=1
    if [ "$SVC_WORKS" -eq 1 ]; then
      # systemctl start is a no-op on already-active units, so it's safe
      # to call unconditionally. Don't fall back to manual nohup if it
      # fails — that's how strangers are born.
      if $SVC start aiterm-pty aiterm-connector 2>/dev/null; then
        if [ $pty_alive -eq 1 ] && [ $conn_alive -eq 1 ]; then
          echo "  Already running."
        else
          echo "  Started."
        fi
      else
        echo -e "  \033[0;31m✗\033[0m Service start failed. Check 'aiterm logs' and"
        echo "      'systemctl status aiterm-pty aiterm-connector'."
        exit 1
      fi
    else
      # Manual mode (no systemd available): only spawn what's missing.
      if [ $pty_alive -eq 0 ]; then
        nohup $PY "$DIR/pty-manager.py" >> "$DIR/connector.log" 2>&1 &
        sleep 1
      fi
      if [ $conn_alive -eq 0 ]; then
        nohup $PY "$DIR/connector.py"   >> "$DIR/connector.log" 2>&1 &
      fi
      if [ $pty_alive -eq 1 ] && [ $conn_alive -eq 1 ]; then
        echo "  Already running."
      else
        echo -e "  \033[0;32m●\033[0m Started"
        echo "  Logs: aiterm logs"
      fi
    fi
    ;;
  stop)
    if [ "$SVC_WORKS" -eq 1 ]; then
      $SVC stop aiterm-connector aiterm-pty 2>/dev/null
    fi
    pkill -f "python3.*$DIR/connector.py" 2>/dev/null
    pkill -f "python3.*$DIR/pty-manager.py" 2>/dev/null
    rm -f "$DIR/connector.lock" "$DIR/pty.sock" 2>/dev/null
    echo "  Stopped."
    ;;
  restart)
    if [ "$SVC_WORKS" -eq 1 ]; then
      # Kill any stranger pty-manager / connector processes first —
      # systemctl restart only touches the units it owns, and a
      # parallel hand-started pty-manager would survive and keep
      # corrupting pty.sock. Detect-and-kill makes restart idempotent.
      pty_strangers=$(find_strangers pty)
      conn_strangers=$(find_strangers connector)
      if [ -n "$pty_strangers" ] || [ -n "$conn_strangers" ]; then
        echo "  Cleaning up stale processes outside systemd..."
        [ -n "$conn_strangers" ] && kill $conn_strangers 2>/dev/null
        [ -n "$pty_strangers" ]  && kill $pty_strangers  2>/dev/null
        sleep 1
        # Anyone still around gets SIGKILL.
        pty_strangers=$(find_strangers pty)
        conn_strangers=$(find_strangers connector)
        [ -n "$conn_strangers" ] && kill -9 $conn_strangers 2>/dev/null
        [ -n "$pty_strangers" ]  && kill -9 $pty_strangers  2>/dev/null
      fi
      if $SVC restart aiterm-pty aiterm-connector 2>/dev/null; then
        echo "  Restarted."
      else
        echo -e "  \033[0;31m✗\033[0m Service restart failed. Check 'aiterm logs' and"
        echo "      'systemctl status aiterm-pty aiterm-connector'."
        exit 1
      fi
    else
      # Pure manual mode: kill everything matching, then start fresh.
      pkill -f "python3.*$DIR/connector.py" 2>/dev/null
      pkill -f "python3.*$DIR/pty-manager.py" 2>/dev/null
      rm -f "$DIR/pty.sock" 2>/dev/null
      sleep 1
      nohup $PY "$DIR/pty-manager.py" >> "$DIR/connector.log" 2>&1 &
      sleep 1
      nohup $PY "$DIR/connector.py"   >> "$DIR/connector.log" 2>&1 &
      echo -e "  \033[0;32m●\033[0m Restarted (PTY manager + connector)"
    fi
    ;;
  logs)
    if [ "$SVC_WORKS" -eq 1 ]; then
      if [ "$SVC" != "systemctl" ]; then
        journalctl --user -u aiterm-connector -u aiterm-pty --no-pager -n "${2:-30}"
      else
        journalctl -u aiterm-connector -u aiterm-pty --no-pager -n "${2:-30}"
      fi
    elif [ -f "$DIR/connector.log" ]; then
      tail -n "${2:-30}" "$DIR/connector.log"
    else
      echo "  No logs found."
    fi
    ;;
  uninstall)
    echo ""
    echo -e "  \033[0;31mUninstall AITerm Connector\033[0m"
    echo ""
    if [ "${2:-}" != "--yes" ]; then
      echo -n "  Are you sure? (y/N) "
      read -r CONFIRM < /dev/tty
      [ "$CONFIRM" != "y" ] && [ "$CONFIRM" != "Y" ] && echo "  Cancelled." && exit 0
    fi
    echo ""
    if [ "$SVC_WORKS" -eq 1 ]; then
      $SVC stop aiterm-connector aiterm-pty 2>/dev/null
      $SVC disable aiterm-connector aiterm-pty 2>/dev/null
    fi
    pkill -f "python3.*$DIR/connector.py" 2>/dev/null
    if [ "$SVC" = "systemctl" ]; then
      rm -f /etc/systemd/system/aiterm-connector.service /etc/systemd/system/aiterm-pty.service
      systemctl daemon-reload 2>/dev/null
    else
      rm -f "$HOME/.config/systemd/user/aiterm-connector.service" "$HOME/.config/systemd/user/aiterm-pty.service" 2>/dev/null
      $SVC daemon-reload 2>/dev/null
    fi
    echo -e "  \033[0;32m✓\033[0m Services removed"
    rm -rf "$DIR"
    echo -e "  \033[0;32m✓\033[0m $DIR removed"
    rm -f "$HOME/.local/bin/aiterm" /usr/local/bin/aiterm 2>/dev/null
    echo -e "  \033[0;32m✓\033[0m CLI removed"
    echo ""
    echo "  AITerm Connector has been completely removed."
    echo ""
    ;;
  *)
    echo ""
    echo "  AITerm Connector"
    echo ""
    echo "  aiterm status      Show connection status"
    echo "  aiterm start       Start connector"
    echo "  aiterm stop        Stop connector"
    echo "  aiterm restart     Restart connector"
    echo "  aiterm update      Update connector from server"
    echo "  aiterm pair        Re-pair this machine (new token, keeps name)"
    echo "  aiterm scan        Scan for AI backends"
    echo "  aiterm doctor      Server security checkup (read-only)"
    echo "  aiterm logs        Show recent logs"
    echo "  aiterm logs 100    Show last 100 log entries"
    echo "  aiterm uninstall   Remove connector completely"
    echo ""
    ;;
esac
